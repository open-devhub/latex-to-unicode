{
  "name": "@devhub-io/latex-to-unicode",
  "version": "2.0.0",
  "description": "Fast and lightweight utility to convert LaTeX strings into clean Unicode characters.",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsup --watch",
    "prebuild": "npm run format",
    "build": "tsup",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\""
  },
  "keywords": [
    "latex",
    "unicode",
    "latex-to-unicode",
    "math",
    "parser",
    "converter",
    "markdown",
    "md",
    "devhub"
  ],
  "author": "Open DevHub",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/open-devhub/latex-to-unicode/issues"
  },
  "homepage": "https://github.com/open-devhub/latex-to-unicode#readme",
  "devDependencies": {
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  }
}
